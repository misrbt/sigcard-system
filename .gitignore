# ============================================================
# ROOT .gitignore — SigCard System (Laravel + React/Vite)
# ============================================================

# ── Sensitive / Environment ──────────────────────────────────
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
*.key
auth.json

# ── Laravel Backend ──────────────────────────────────────────
backend/vendor/
backend/node_modules/
backend/public/build/
backend/public/hot/
backend/public/storage/
backend/storage/*.key
backend/storage/pail/
backend/storage/logs/*.log
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
backend/bootstrap/cache/*.php
backend/.phpunit.result.cache
backend/.phpunit.cache/
backend/Homestead.json
backend/Homestead.yaml
backend/TEST_ACCOUNTS.md

# ── Frontend (React/Vite) ────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE & Editor ─────────────────────────────────────────────
.idea/
.vscode/
!.vscode/extensions.json
.fleet/
.nova/
.zed/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
.phpactor.json

# ── Misc ─────────────────────────────────────────────────────
*.zip
*.tar.gz
*.bak
*.tmp
